<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="com.parsec.aika.common.mapper.CommentMapper">
    <resultMap id="BaseResultMap" type="com.parsec.aika.common.model.entity.Comment">
        <id column="id" jdbcType="INTEGER" property="id" />
        <result column="content" jdbcType="VARCHAR" property="content" />
        <result column="voiceUrl" jdbcType="VARCHAR" property="voiceUrl" />
        <result column="postId" jdbcType="INTEGER" property="postId" />
        <result column="creator" jdbcType="BIGINT" property="creator" />
        <result column="createdAt" jdbcType="TIMESTAMP" property="createdAt" />
        <result column="replyTo" jdbcType="VARCHAR" property="replyTo" typeHandler="com.baomidou.mybatisplus.extension.handlers.JacksonTypeHandler" />
        <result column="type" jdbcType="VARCHAR" property="type" />
    </resultMap>
    <select id="pageList" parameterType="com.parsec.aika.common.model.vo.req.CommentQueryVo" resultMap="BaseResultMap">
        SELECT * FROM t_comment
        WHERE postId = #{req.postId}
        ORDER BY createdAt ASC
    </select>
</mapper>
